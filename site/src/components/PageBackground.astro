---
/**
 * Site background — the launcher's metallic counterpart to the GWToolbox
 * continent maps. Pure CSS, no images: a faint diamond/plate lattice (echoing
 * the angular facets of the helmet icon) over a cool steel vignette. Persisted
 * across view transitions so it never re-paints mid-navigation.
 */
---

<div class="page-bg" aria-hidden="true" transition:persist="page-bg">
  <div class="page-bg-lattice"></div>
  <div class="page-bg-overlay"></div>
</div>

<style>
  .page-bg {
    position: fixed;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    overflow: hidden;
  }
  /* Faceted diamond lattice — two crossing line sets form a brushed-plate
     pattern. Kept very low contrast so content stays legible. */
  .page-bg-lattice {
    position: absolute;
    inset: -10%;
    background-image:
      repeating-linear-gradient(
        45deg,
        rgba(203, 213, 225, 0.035) 0,
        rgba(203, 213, 225, 0.035) 1px,
        transparent 1px,
        transparent 44px
      ),
      repeating-linear-gradient(
        -45deg,
        rgba(203, 213, 225, 0.035) 0,
        rgba(203, 213, 225, 0.035) 1px,
        transparent 1px,
        transparent 44px
      );
    mask-image: radial-gradient(ellipse 70% 80% at 50% 0%, black 0%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 70% 80% at 50% 0%, black 0%, transparent 75%);
  }
  /* Cool steel glow from the top, fading to near-black so the page reads as a
     dark armory backdrop. */
  .page-bg-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% -10%, rgba(47, 111, 168, 0.14) 0%, transparent 60%),
      radial-gradient(ellipse 90% 70% at 50% 110%, rgba(20, 23, 28, 0.6) 0%, transparent 70%);
  }
</style>

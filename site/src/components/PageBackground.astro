---
/**
 * Site background — a fixed Guild Wars wallpaper (the Catacombs key art) shown
 * at low opacity beneath a darkening overlay, the same approach the GWToolbox++
 * site uses for its continent maps. The overlay is dark in the centre column
 * where content sits and fades toward the edges so the art shows through in the
 * gutters, with a steel-blue top glow to match the launcher's theme. Persisted
 * across view transitions so it never repaints mid-navigation.
 */
---

<div class="page-bg" aria-hidden="true" transition:persist="page-bg">
  <div class="page-bg-image"></div>
  <div class="page-bg-overlay"></div>
</div>

<style>
  .page-bg {
    position: fixed;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    overflow: hidden;
  }
  .page-bg-image {
    position: absolute;
    inset: 0;
    background-image: url('/backgrounds/catacombs.webp');
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    opacity: 0.35;
  }
  .page-bg-overlay {
    position: absolute;
    inset: 0;
    /* Dark in the centre column where content sits, fading toward the viewport
       edges so the wallpaper shows through in the gutters; plus a cool steel
       glow from the top to tie it to the launcher's accent. */
    background:
      radial-gradient(ellipse 55% 50% at 50% -5%, rgba(47, 111, 168, 0.18) 0%, transparent 60%),
      radial-gradient(
        ellipse 55% 75% at center,
        rgba(8, 9, 11, 0.82) 0%,
        rgba(8, 9, 11, 0.7) 45%,
        rgba(8, 9, 11, 0.2) 100%
      );
  }
</style>
